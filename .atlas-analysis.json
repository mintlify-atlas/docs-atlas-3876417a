  },
  "keyFeatures": [
    "Restaurant search with logical and fuzzy matching",
    "Barcelona metro graph generation",
    "Combined city and metro pathfinding",
    "Accessibility support for special access requirements",
    "Route visualization with time estimates",
    "Telegram bot interface with location sharing"
  ],
  "publicApiSurface": [
    "/start - Initialize bot conversation",
    "/help - Show available commands",
    "/author - Show project authors",
    "/find <query> - Search for restaurants",
    "/info <number> - Show restaurant details",
    "/guide <number> - Display route to restaurant",
    "/time <number> - Calculate travel time",
    "/accessibility <yes/no> - Set accessibility requirements",
    "restaurants.read() - Read restaurants from CSV",
    "restaurants.find_logic() - Search with logical operators",
    "restaurants.get_restaurants() - Get filtered restaurant list",
    "metro.get_metro_graph() - Generate metro graph",
    "metro.read_stations() - Read station data",
    "metro.read_accesses() - Read access data",
    "city.get_city_graph() - Generate combined city graph",
    "city.find_path() - Find shortest path",
    "city.plot_path() - Visualize route",
    "city.get_osmnx_graph() - Get street graph"
  ]
}
