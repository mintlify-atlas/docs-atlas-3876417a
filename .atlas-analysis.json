  "projectType": "cli-tool",
  "projectName": "Telegram Bot Guider",
  "projectDescription": "A Telegram bot that helps users navigate to restaurants in Barcelona using metro and walking routes with accessibility support.",
  "theme": "palm",
  "primaryColor": "#0066CC",
  "lightColor": "#4D94FF",
  "darkColor": "#003D7A",
